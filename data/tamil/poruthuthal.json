{
    "title": "1. பொருத்துதல் - பொருத்தமான பொருளை அறிதல்",
    "notes": [
        "அகழ்வாரைத் தாங்கும் நிலம்போலத் தம்மை இகழ்வார்ப் பொறுத்தல் தலை - இதற்கான பொருள்: பூமி தன்னைத் தோண்டுபவரைத் தாங்குவது போல, நம்மை இகழ்பவரைப் பொறுத்துக் கொள்ள வேண்டும்.",
        "திங்கள் - நிலவு",
        "ஞாயிறு - சூரியன்",
        "அலர்தல் - மலர்தல்",
        "திகிரி - ஆணைச்சக்கரம்",
        "மேரு - இமயமலை",
        "நாமநீர் - அச்சம்தரும் கடல்",
        "அளி - கருணை"
    ],
    "quiz": [
        {
            "q": "திங்கள் என்பதன் சரியான பொருள் என்ன?",
            "options": [
                "சூரியன்",
                "நிலவு",
                "விண்மீன்",
                "மலை"
            ],
            "ans": 1
        },
        {
            "q": "பூமி தன்னைத் தோண்டுபவரைத் தாங்குவது போல, நாம் என்ன செய்ய வேண்டும்?",
            "options": [
                "பழிவாங்க வேண்டும்",
                "அழ வேண்டும்",
                "இகழ்பவரைப் பொறுக்க வேண்டும்",
                "விலகிச் செல்ல வேண்டும்"
            ],
            "ans": 2
        },
        {
            "q": "ஞாயிறு என்பதன் பொருள்?",
            "options": [
                "சூரியன்",
                "பூமி",
                "காற்று",
                "நீர்"
            ],
            "ans": 0
        },
        {
            "q": "மேரு என்பதன் சரியான பொருள் கீழ்க்கண்டவற்றுள் எது?",
            "options": [
                "ஆணைச்சக்கரம்",
                "இமயமலை",
                "கடல்",
                "கருணை"
            ],
            "ans": 1
